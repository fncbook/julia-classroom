{
  "name": "Julia 1.11.9",
  "image": "ghcr.io/fncbook/julia-classroom:1.11.9",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.juliaup/bin",
    "JULIA_PROJECT": "/home/vscode"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "julialang.language-julia",
        "ms-toolsai.jupyter"
      ]
    }
  },

  "forwardPorts": [8888, 1234]
}
