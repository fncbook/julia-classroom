{
  "name": "Julia 1.11.9",
  "image": "ghcr.io/fncbook/julia-classroom:1.11.9",

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.juliaup/bin",
    "JULIA_DEPOT_PATH": "/opt/julia-depot",
    "JULIA_PROJECT": "/opt/julia-env"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "julialang.language-julia",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "julia.environmentPath": "/opt/julia-env"
      }
    }
  },

  "forwardPorts": [8888, 1234]
}
